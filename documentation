<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#FAFAF8;--card:#FFFFFF;--border:#E4E2DB;--text:#1A1A18;--muted:#7A786F;--accent:#1D4E3E;--accent-light:#E8F0EC;--blue:#378ADD;--blue-light:#E6F1FB;--amber:#BA7517;--amber-light:#FAEEDA;--radius:10px;--shadow:0 1px 3px rgba(0,0,0,0.06)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.7}
